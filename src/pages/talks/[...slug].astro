---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const talks = await getCollection('talks');
  return talks.map((talk) => ({
    params: { slug: talk.slug },
    props: { talk },
  }));
}

const { talk } = Astro.props;
const { Content } = await talk.render();

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
}

const base = import.meta.env.BASE_URL;
const rawBase = base.endsWith('/') ? base : `${base}/`;
---

<BaseLayout title={talk.data.title}>
  <div class="section">
    <a href={rawBase} class="back-link">&larr; Back to Talks</a>
    <h1 class="talk-detail-title">{talk.data.title}</h1>
    <div class="talk-detail-meta">
      <span>{formatDate(talk.data.date)}</span>
      <span>{talk.data.speaker}</span>
      {talk.data.affiliation && <span>{talk.data.affiliation}</span>}
    </div>
    {talk.data.image && <img src={talk.data.image} alt="" class="talk-detail-image" />}
    <div class="talk-detail-content">
      <Content />
    </div>
    {talk.data.slides && <a href={talk.data.slides} class="talk-detail-slides">View Slides</a>}
  </div>
</BaseLayout>
